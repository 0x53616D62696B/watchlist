{
    //** This is only a backup of my settings.json file. These settings are not applied**//

    //* Files to exclude from explorer
    "files.exclude": {
        "**/__pycache__": true,
    },

    //* VS Code environment
    // Wrapping
    "editor.wordWrapColumn": 130,
    "editor.wordWrap": "wordWrapColumn",
    "[markdown]": {
        "editor.wordWrapColumn": 130,
        "editor.wordWrap": "wordWrapColumn",
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    //"rewrap.wrappingColumn": 120,
    //"rewrap.autoWrap.enabled": true,

    // Editor style
    "editor.semanticHighlighting.enabled": true,
    "window.restoreWindows": "preserve",
    "editor.stickyScroll.enabled": true,
    "editor.tabCompletion": "on",
    "editor.minimap.enabled": false,
    "workbench.iconTheme": "vscode-icons",
    "vsicons.dontShowNewVersionMessage": true,
    "workbench.editor.wrapTabs": true,

    // Rulers
    "editor.rulers": [
        /*{
            "column": 90,
            "color": "#5a5a5a80"
        },
        {
            "column": 120,
            "color": "#ff0000"
        }*/
        {
            "column": 120,
            "color": "#e7e0e0da"
        },
        {
            "column": 130,
            "color": "#008cffcc"
        }
    ],
    "[git-commit]": {
        "editor.rulers": [
            50
        ]
    },
    //"workbench.colorCustomizations": {
    //"editorRuler.foreground": "#ff4081"
    //}

    //* Hide Comments
    "hideComments.defaultEnabled": false,
    "editor.tokenColorCustomizations": {
        "comments": "",
        "textMateRules": []
    },

    //* C++
    // CMake
    //"cmake.cmakePath": "C:\\Users\\patrik.maraczek\\AppData\\Local\\Programs\\CMake\\bin\\cmake.exe",
    "cmake.generator": "",
    "cmake.configureOnOpen": true,
        "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "cmake.options.statusBarVisibility": "compact",
    "cmake.options.advanced": {
        "kit": {
            "statusBarVisibility": "visible"
        },
        "workflow": {
            "statusBarVisibility": "hidden"
        },
        "cpack": {
            "statusBarVisibility": "hidden"
        },
        "ctest": {
            "statusBarVisibility": "hidden"
        },
    },
    "makefile.configureOnOpen": false,
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    // Clang-format
    "C_Cpp.formatting": "clangFormat",
    //"clang-format.executable": "c:\\LLVM\\bin\\clang-format.exe",
    "clang-format.executable": "/usr/bin/clang-format",
    //"C_Cpp.clang_format_fallbackStyle": "Google",
    //"C_Cpp.clang_format_style": "file", // when using .clang-format file
    "C_Cpp.clang_format_style": "{ BasedOnStyle: Google, IndentWidth: 4, ColumnLimit: 150 }",
    // "clang-format.language.cpp.style": "Google",
    // "clang-format.language.cpp.fallbackStyle": "Google",

    //* IntelliSense
    //"C_Cpp.intelliSenseCacheSize": 512, // Cache size in MB
    //"C_Cpp.intelliSenseCachePath": "C:\\Users\\patrik.maraczek\\.vscode\\intelliSenseCache",
    "C_Cpp.files.exclude": {
        "**/build/**": true
    },


    //* Git
    "github.gitProtocol": "ssh",
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "git.ignoreRebaseWarning": false,

    //* Github Copilot
    "github.copilot.nextEditSuggestions.enabled": true,
    //"github.copilot.enable": true,

    //* Python
    // Virtual environment activation
    "python.terminal.activateEnvironment": true,

    "[python]": {
        // Autopep8 formatter
        "editor.defaultFormatter": "ms-python.autopep8",
        "editor.formatOnSave": false,
        "editor.formatOnType": false,
    },

    // flake8
    "flake8.args": [
        "--max-line-length=120",
        "--indent-size=4",
    ],
    // pylint
    "pylint.args": [
        "--max-line-length=120",
        "--indent-string='    '",
        "--disable=fixme",
        //"--rcfile",
        //"${workspaceFolder}\\setup.cfg"
    ],
    
    // Doctring Formatter
    "autoDocstring.docstringFormat": "google-notypes",

    //* enable discord tracking
    "discord.removeRemoteRepository": true,
    "discord.removeLowerDetails": true,

    //* ------- MD support ------------------------------
    "markdown.extension.toc.levels": "2..6",

    //* ------- Grammarly support -----------------------
    "grammarly.startTextCheckInPausedState": true,
    "grammarly.selectors": [
        {
            "language": "python",
            "scheme": "file"
        },
        {
            "language": "markdown",
            "scheme": "file"
        }
    ],
    //"grammarly.files.include": ["**/README.md", "**/readme.md", "**/*.txt"],
    //"grammarly.files.exclude": [],

    //* -------- Code Spell Checker Configuration --------
    "cSpell.enabled": false,
    // The Language locale to use when spell checking. "en", "en-US" and "
    "cSpell.language": "en",
    // The minimum length of a word before checking it against a dictionary.
    "cSpell.minWordLength": 4,
    // Specify file types to spell check.
    "cSpell.enabledFileTypes": {
        "markdown": true,
        "python": true,
        "plaintext": true,
        "yml": true
    },

    //* ------- SSH settings ---------------------------
    "remote.SSH.remotePlatform": {
        "192.168.198.51": "windows",
        "172.24.198.1": "windows",
        "DatasystePC": "windows",
        "DatasystemPC": "windows",
        "172.20.7.0": "windows",
        "DatasystemPC_VPN_Europe": "windows",
        "DatasystemPC_Office": "windows",
        "10.170.111.42": "linux"
    },

    //* ------- GlassIt --------------------------------
    "glassit.alpha": 255, //230,

    //* ------- Dev Containers ---------------------------
    "dev.containers.executeInWSL": true,

    //* Other Settings - Automatically added by VS Code
    "graphviz-interactive-preview.renderLockAdditionalTimeout": -1,
    "gitlens.gitCommands.skipConfirmations": [
        "fetch:command",
        "switch:command",
        "branch-create:command"
    ],
    "update.mode": "manual",
    "editor.accessibilitySupport": "off",
    "explorer.confirmDelete": false,
    "hediet.vscode-drawio.resizeImages": null,
    "gitlens.rebaseEditor.ordering": "asc",
    "gitlens.advanced.messages": {
        "suppressCreatePullRequestPrompt": true
    },
    "remote.autoForwardPortsSource": "hybrid",
    "diffEditor.ignoreTrimWhitespace": false,
    "gitlens.views.repositories.showStashes": true,
}