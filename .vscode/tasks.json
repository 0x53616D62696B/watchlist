{
    "version": "2.0.0",
    "windows": {
        "options": {
            "shell": {
                "executable": "cmd.exe",
                "args": [
                    "/C",
                    "\"C:/Program Files (x86)/Microsoft Visual Studio/BuildTools/Common7/Tools/VsDevCmd.bat\"",
                    "&&"
                ]
            }
        }
    },
    "tasks": [
        {
            "type": "shell",
            "label": "cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/Fe:",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "CMake: configure with Tracy",
            "command": "cmake",
            "args": [
                "--preset",
                "with-profiling"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "CMake: configure with Tracy NO_EXIT",
            "command": "cmake",
            "args": [
                "--preset",
                "with-profiling-no-exit"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "CMake: build Application with Tracy",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "with-profiling",
                "--target",
                "Application"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build"
        },
        {
            "type": "shell",
            "label": "CMake: build Application with Tracy NO_EXIT",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "with-profiling-no-exit",
                "--target",
                "Application"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build"
        },
        {
            "type": "shell",
            "label": "CMake: build active target",
            "command": "${command:cmake.tasksBuildCommand}",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build"
        },
        {
            "label": "CMake: configure and build Application with Tracy",
            "dependsOrder": "sequence",
            "dependsOn": [
                "CMake: configure with Tracy",
                "CMake: build Application with Tracy"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake: configure and build Application with Tracy NO_EXIT",
            "dependsOrder": "sequence",
            "dependsOn": [
                "CMake: configure with Tracy NO_EXIT",
                "CMake: build Application with Tracy NO_EXIT"
            ],
            "problemMatcher": []
        }
    ]
}
