{
    //* C++
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.cStandard": "c11",
    "C_Cpp.autoAddFileAssociations": false,
    //"cmake.cmakePath": "C:\\Users\\patrik.maraczek\\AppData\\Local\\Programs\\CMake\\bin\\cmake.exe",
    "cmake.generator": "Ninja",
    "cmake.parallelJobs": 0,
    "cmake.configureOnOpen": true,
    "makefile.configureOnOpen": false,
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    //"clang-format.executable": "c:\\LLVM\\bin\\clang-format.exe",
    "clang-format.assumeFilename": ".clang-format",
    "c-cpp-flylint.cppcheck.inconclusive": true,
    "c-cpp-flylint.flawfinder.enable": false,
    "c-cpp-flylint.flexelint.enable": false,
    "c-cpp-flylint.lizard.enable": false,
    "c-cpp-flylint.clang.enable": false,
    "c-cpp-flylint.excludeFromWorkspacePaths": [
        "libs"
    ],
    "c-cpp-flylint.cppcheck.addons": [
        "cert",
        "misc"
    ],
    "c-cpp-flylint.cppcheck.extraArgs": [
        "--enable=warning,style,performance,portability,information"
    ],
    "c-cpp-flylint.cppcheck.suppressions": [
        "noExplicitConstructor",
        "misc-implicitlyVirtual"
    ],
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
}