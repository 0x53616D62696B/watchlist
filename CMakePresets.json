{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "description": "Default build configuration",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_MAKE_PROGRAM": "C:/Users/patrik.maraczek/DevTools/Microsoft Visual Studio/BuildTools/Common7/IDE/CommonExtensions/Microsoft/CMake/Ninja/ninja.exe"
            }
        },
        {
            "name": "with-profiling",
            "displayName": "With Tracy Profiling",
            "description": "Enable Tracy profiling",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/profiling",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "DebugTracy",
                "ENABLE_PROFILING": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "with-profiling",
            "configurePreset": "with-profiling"
        }
    ]
}
